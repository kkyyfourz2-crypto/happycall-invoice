// ===== AI ANALYSIS =====
async function analyzeAll() {
  if (!apiKey) { showModal('API 키 필요', 'API 키를 먼저 입력하고 저장해주세요.\n상단 노란 바에서 입력할 수 있어요.'); return; }
  if (uploadedFiles.length === 0) return;

  const btn = document.getElementById('analyzeBtn');
  btn.disabled = true;
  btn.textContent = '🤖 AI 인식 중...';
  document.getElementById('progressBar').style.display = 'block';
  extractedData = [];

  for (let i = 0; i < uploadedFiles.length; i++) {
    document.getElementById('statusMsg').textContent = `(${i+1}/${uploadedFiles.length}) ${uploadedFiles[i].name} 인식 중...`;
    document.getElementById('progressFill').style.width = Math.round(((i+1)/uploadedFiles.length)*100) + '%';
    try {
      const b64 = await fileToBase64(uploadedFiles[i].file);
      const items = await analyzeImage(b64, i, uploadedFiles[i].type);
      extractedData.push(...items);
    } catch(e) {
      console.error(e);
      document.getElementById("statusMsg").textContent = `⚠️ 오류: ${e.message}`;
      if (e.message.includes("API 키") || e.message.includes("authentication")) {
        btn.disabled = false;
        btn.textContent = "🤖 AI 전표 자동 인식 시작";
        document.getElementById("progressBar").style.display = "none";
        return;
      }
    }
    renderPreviews();
  }

  document.getElementById('progressBar').style.display = 'none';
  document.getElementById('statusMsg').textContent = `✓ 완료! 총 ${extractedData.length}건 인식됨`;
  btn.disabled = false;
  btn.textContent = '🤖 재인식';
  document.getElementById('badge-review').textContent = extractedData.length;
  updateSidebar();
  showPanel('review');
}

function fileToBase64(file) {
  return new Promise((res, rej) => {
    const r = new FileReader();
    r.onload = () => res(r.result.split(',')[1]);
    r.onerror = rej;
    r.readAsDataURL(file instanceof File ? file : file.file || file);
  });
}

async function analyzeImage(b64, fileIdx, forcedPayment) {
  const cleanKey = apiKey.trim().replace(/[^\x00-\x7F]/g, '').replace(/\s/g, '');
  const cleanVision = visionKey.trim().replace(/[^\x00-\x7F]/g, '').replace(/\s/g, '');

  const resp = await fetch('/api/analyze', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      image: b64,
      payment_type: forcedPayment || null,
      anthropic_key: cleanKey,
      vision_key: cleanVision
    })
  });

  const data = await resp.json();
  if (data.error) throw new Error(data.error);

  return (data.results || []).map(item => ({
    ...item,
    _id: Math.random().toString(36).slice(2),
    _fileIdx: fileIdx,
  }));
}


