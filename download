function matchVendor(nameStr, addrStr) {
  const n = (nameStr||'').replace(/\s/g,'').toLowerCase();
  const a = (addrStr||'').replace(/\s/g,'').toLowerCase();
  for (const [std, {aliases, addr}] of Object.entries(WOLMAL_MAP)) {
    for (const alias of aliases) {
      if (alias.replace(/\s/g,'').toLowerCase() && n.includes(alias.replace(/\s/g,'').toLowerCase())) return {name:std, confident:true};
    }
    for (const key of addr) {
      if (key.replace(/\s/g,'').toLowerCase() && a.includes(key.replace(/\s/g,'').toLowerCase())) return {name:std, confident:true};
    }
  }
  return {name: nameStr||'', confident: false};
}

function normalizePayment(raw) {
  const r = (raw||'').replace(/\s/g,'').toLowerCase();
  if (/월말|月末|월말결제/.test(r)) return '월말';
  if (/현금|선불|착불|현금결제|후불/.test(r)) return '현금';
  if (/계좌|계좌이체|이체|무통장/.test(r)) return '계좌';
  return null;
}

