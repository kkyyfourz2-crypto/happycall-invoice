function renderSalary() {
  const tbody = document.getElementById('salaryTbody');

  // Compute 지하철 stats
  const subwayStats = {};
  extractedData.forEach(d => {
    const name = d.배송원||'';
    if (!name) return;
    if (!subwayStats[name]) subwayStats[name] = {count:0, amount:0};
    subwayStats[name].count++;
    subwayStats[name].amount += parseInt(d.가격)||parseInt(d.금액)||0;
  });

  salaryData = WORKER_MASTER.map((w, i) => {
    let count = 0, amount = 0;
    if (w.type === '지하철') {
      const s = subwayStats[w.name] || {count:0, amount:0};
      count = s.count; amount = s.amount;
    } else {
      const m = magnetData[w.name] || {count:0, amount:0};
      count = m.count; amount = m.amount;
    }
    return { ...w, workdays: 0, count, amount };
  }).filter(w => w.count > 0 || w.type === '카드');

  tbody.innerHTML = salaryData.map((w, i) => {
    const subsidy = w.subsidy;
    const totalIncome = w.amount + subsidy;
    const incomeTax = Math.floor(totalIncome * 0.03 / 10) * 10;
    const residentTax = Math.floor(incomeTax * 0.1 / 10) * 10;
    const activation = subsidy > 0 ? 50000 : 0;
    const netPay = w.amount - activation - incomeTax - residentTax;

    return `<tr>
      <td style="color:var(--text3)">${i+1}</td>
      <td><strong>${w.name}</strong></td>
      <td><span class="chip chip-${w.type}">${w.type}</span></td>
      <td><input type="number" min="0" max="31" value="${w.workdays}" 
        onchange="updateWorkdays(${i},this.value)" style="width:60px"></td>
      <td style="text-align:right">${w.count.toLocaleString()}</td>
      <td style="text-align:right;font-weight:600">${w.amount.toLocaleString()}</td>
      <td style="text-align:right">${subsidy.toLocaleString()}</td>
      <td style="text-align:right">${totalIncome.toLocaleString()}</td>
      <td style="text-align:right">${incomeTax.toLocaleString()}</td>
      <td style="text-align:right">${residentTax.toLocaleString()}</td>
      <td style="text-align:right">${activation.toLocaleString()}</td>
      <td style="text-align:right;color:var(--green);font-weight:700">${netPay.toLocaleString()}</td>
    </tr>`;
  }).join('');
}

