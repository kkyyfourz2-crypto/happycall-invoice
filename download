function updateField(id, field, val) {
  const item = extractedData.find(d => d._id === id);
  if (item) { item[field] = val; item.uncertain = false; }
  updateSidebar();
}

function deleteRow(id) {
  extractedData = extractedData.filter(d => d._id !== id);
  renderReview();
}

function addRow(type) {
  extractedData.push({
    _id: Math.random().toString(36).slice(2), _fileIdx: -1,
    결제방식: type, 날짜: '', 수요처: '', 출발지: '', 도착지: '',
