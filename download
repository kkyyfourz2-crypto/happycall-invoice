  document.getElementById('sb-total').textContent = total.toLocaleString();
}

// ===== MAGNET FILE =====
function handleMagnet(input) {
  const file = input.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = (e) => {
    const wb = XLSX.read(e.target.result, {type:'array'});
    const ws = wb.Sheets[wb.SheetNames[0]];
    const data = XLSX.utils.sheet_to_json(ws, {header:1, defval:''});

    magnetData = {};
    let currentName = '';
    let currentCount = 0, currentAmt = 0;

    for (const row of data) {
      const name = row[3];
      const type = row[5];
      const qty = parseFloat(row[7]) || 0;
      const amt = parseFloat(row[8]) || 0;

      if (name && typeof name === 'string' && name.trim() && type !== '소계') currentName = name.trim();
      if (type === '소계' && currentName) {
        magnetData[currentName] = { count: Math.round(qty), amount: Math.round(amt) };
        currentCount = 0; currentAmt = 0;
      }
    }

    const tbody = document.getElementById('magnetTbody');
    tbody.innerHTML = Object.entries(magnetData).map(([name, d]) =>
      `<tr><td>${name}</td><td>${d.count.toLocaleString()}</td><td>${d.amount.toLocaleString()}원</td></tr>`
    ).join('');
    document.getElementById('magnetResult').style.display = 'block';
    document.getElementById('magnetNotif').textContent = `✓ ${Object.keys(magnetData).length}명 카드배송팀 데이터 로드 완료`;
  };
  reader.readAsArrayBuffer(file);
}

