// ===== EXCEL EXPORT: STATEMENTS =====
function exportStatements() {
  const wb = XLSX.utils.book_new();
  const vendors = {};
  extractedData.filter(d=>d.결제방식==='월말').forEach(d => {
    const vm = matchVendor(d.수요처, d.출발지);
    const vname = vm.name || d.수요처 || '미분류';
    if (!vendors[vname]) vendors[vname] = [];
    vendors[vname].push(d);
  });

  if (Object.keys(vendors).length === 0) {
    showModal('알림', '월말 데이터가 없습니다.');
    return;
  }

  Object.entries(vendors).forEach(([vname, items]) => {
    const total = items.reduce((s,d)=>s+(parseInt(d.가격)||0),0);
    const shData = [
      [`거래명세서 - ${vname}`],
      [],
      ['날짜', '출발지', '도착지', '배송원', '금액', '비고'],
      ...items.map(d => [d.날짜, d.출발지, d.도착지, d.배송원, parseInt(d.가격)||0, d.비고||'']),
      [],
      ['', '', '', '합계', total, '']
    ];
    const sname = vname.slice(0, 28).replace(/[\/\\?*\[\]]/g,'');
    XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(shData), sname || '수요처');
  });

  XLSX.writeFile(wb, `해피콜_거래명세서_${new Date().toLocaleDateString('ko-KR').replace(/\./g,'').replace(/ /g,'')}.xlsx`);
}

